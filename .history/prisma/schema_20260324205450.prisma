generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  reviews   Review[]
}

model Review {
  id             String   @id @default(uuid())
  language       String
  codeSnippet    String

  bugs           String?
  improvements   String?
  complexity     String?
  refactoredCode String?

  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
  user .User @relation(fields: [userId])
}